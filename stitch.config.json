{
    "gameConsoleStyle": {
        "base": "color:#808080;",
        "lines": [
            {
                "base": "color:#4A4A4A;",
                "pattern": "^Pause event has been"
            },
            {
                "base": "color:#4A4A4A;",
                "pattern": "^Not recreating swapchain"
            },
            {
                "base": "color:#808080;",
                "pattern": "is cropped, sprites used by Spine must be uncropped$"
            },
            {
                "base": "color: #FFD900",
                "pattern": "\\bwarn(ing)?\\b"
            },
            {
                "base": "color: #FF0000",
                "pattern": "\\berror\\b"
            },
            {
                "pattern": "^(?<time>[^|]+)\\|\\s(?<level>DEBUG)\\s\\|\\s(?<caller>[^>]+)>>(?<msg>.*)",
                "styles": {
                    "caller": "color: #66b3ff",
                    "level": "color: #e6e6e6",
                    "msg": "color: #e6e6e6",
                    "time": "color: #66b3ff"
                }
            },
            {
                "pattern": "^(?<time>[^|]+)\\|\\s(?<level>INFO)\\s\\|\\s(?<caller>[^>]+)>>(?<msg>.*)",
                "styles": {
                    "caller": "color: #66b3ff",
                    "level": "color: #66ff66",
                    "msg": "color: #66ff66",
                    "time": "color: #66b3ff"
                }
            },
            {
                "pattern": "^(?<time>[^|]+)\\|\\s(?<level>WARNING)\\s\\|\\s(?<caller>[^>]+)>>(?<msg>.*)",
                "styles": {
                    "caller": "color: #66b3ff",
                    "level": "color: #FFD900",
                    "msg": "color: #FFD900",
                    "time": "color: #66b3ff"
                }
            },
            {
                "pattern": "^(?<time>[^|]+)\\|\\s(?<level>ERROR)\\s\\|\\s(?<caller>[^>]+)>>(?<msg>.*)",
                "styles": {
                    "caller": "color: #66b3ff",
                    "level": "color: #FF0000",
                    "msg": "color: #FF0000",
                    "time": "color: #66b3ff"
                }
            },
            {
                "pattern": "^(?<time>[^|]+)\\|\\s(?<level>CRITICAL)\\s\\|\\s(?<caller>[^>]+)>>(?<msg>.*)",
                "styles": {
                    "caller": "color: #66b3ff",
                    "level": "color: #FF0000; font-weight: bold",
                    "msg": "color: #FF0000; font-weight: bold",
                    "time": "color: #66b3ff"
                }
            },
            {
                "base": "color: [#808080](https://github.com/bscotch/stitch/issues/808080);",
                "description": "Bscotch Echo",
                "pattern": "^(?<entity>(?<struct>struct)|(?<constructor>Struct\\.(?<constructorName>[^|]+))|(?<rumpus>o_rumpus[^|]+)|(?<http>o_http_controller)|(?<object>o_[^|]+))\\|(?<time>[^|]+)\\| (?<message>.*)",
                "styles": {
                    "constructor": "color: #4FE2C2",
                    "http": "color:#0095FF",
                    "message": "color:white;",
                    "object": "color: #FF9D00",
                    "rumpus": "color:#0095FF",
                    "struct": "color:cyan"
                }
            }
        ]
    }
}
